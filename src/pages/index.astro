              <div class="mock-line"><span class="mono">1029343</span><span class="mono">8241</span><span class="mono">F</span><span class="mono">1983</span></div>
              <div class="mock-line"><span class="mono">1029344</span><span class="mono">8241</span><span class="mono">M</span><span class="mono">1971</span></div>
              <div class="mock-line mock-dim"><span class="mono subtle">...</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="final-cta">
    <div class="container">
      <h2>Building something that needs trustworthy synthetic data?</h2>
      <p class="muted">Get in touch. We respond personally.</p>
      <a href="/contact" class="btn">Contact us →</a>
    </div>
  </section>

</Base>

<style>
  /* Hero */
  .hero {
    position: relative;
    padding: var(--space-24) 0 var(--space-16);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 30%, var(--accent-glow) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 80%, rgba(139, 92, 246, 0.08) 0%, transparent 50%);
    pointer-events: none;
  }

  .hero-hex {
    position: absolute;
    top: 0;
    right: 0;
    width: 60%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .hero-hex svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Hide hex grid on mobile — hero needs to breathe on small screens */
  @media (max-width: 640px) {
    .hero-hex {
      display: none;
    }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 820px;
  }

  .hero-tag {
    display: inline-block;
    padding: var(--space-2) var(--space-3);
    background: var(--surface);
    border: 1px solid var(--border-strong);
    border-radius: 100px;
    font-size: 0.85rem;
    color: var(--fg-muted);
    margin-bottom: var(--space-6);
  }

  .hero h1 {
    margin-bottom: var(--space-6);
  }

  .hero-lead {
    font-size: 1.2rem;
    line-height: 1.55;
    color: var(--fg-muted);
    margin-bottom: var(--space-8);
    max-width: 640px;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  /* Section labels */
  .section-label {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent);
    margin-bottom: var(--space-3);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* Problem section */
  .problem-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-8);
    margin-top: var(--space-8);
  }

  .problem-item {
    position: relative;
    padding-top: var(--space-6);
  }

  .problem-number {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--fg-subtle);
    margin-bottom: var(--space-3);
  }

  /* Answer section */
  .answer {
    background: var(--bg-elevated);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .answer-grid {
    display: grid;

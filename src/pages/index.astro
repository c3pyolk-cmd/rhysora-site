---
import Base from '../layouts/Base.astro';
---

<Base
  title="Rhysora — Trustworthy synthetic UK primary-care data"
  description="Realistic synthetic UK primary care patient data for research, pharma HEOR, and EHR testing. Values traceable to published sources, datasets reproducible by seed."
>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-hex" aria-hidden="true">
      <svg id="hero-hex-svg" viewBox="0 0 800 700" preserveAspectRatio="xMaxYMid slice" xmlns="http://www.w3.org/2000/svg">
        <!-- Base hex grid (built procedurally by the animation script so pulses can traverse it) -->
        <g id="hero-hex-base" class="hex-base" fill="none" stroke="#2dd4bf" stroke-width="0.9" opacity="0.22"></g>

        <!-- 5 Scattered accent hexagons — slow breathing -->
        <g id="hero-hex-accent" class="hex-accent" fill="none" stroke="#2dd4bf" stroke-width="1.3" opacity="0.42">
          <polygon points="290,186 309,197 309,219 290,230 271,219 271,197" />
          <polygon points="442,322 461,333 461,355 442,366 423,355 423,333" />
          <polygon points="670,254 689,265 689,287 670,298 651,287 651,265" />
          <polygon points="556,436 575,447 575,469 556,480 537,469 537,447" />
          <polygon points="366,526 385,537 385,559 366,570 347,559 347,537" />
        </g>

        <!-- Traveling pulses injected here -->
        <g id="hero-hex-traces"></g>
      </svg>
    </div>
    <div class="container hero-inner">
      <div class="hero-tag">Synthetic data, honestly built</div>
      <h1>
        Synthetic UK primary-care data
        <span class="accent-text">you can defend.</span>
      </h1>
      <p class="hero-lead">
        Rhysora generates realistic, fully-synthetic patient records for research,
        testing, and methodology development. No real patient data is used at
        any stage, so there is nothing to anonymise and no Data Sharing
        Agreement to sign. Values trace to published sources; values we cannot
        source are flagged as estimates. Every dataset is reproducible by
        anyone with the same settings.
      </p>
      <div class="hero-actions">
        <a href="/products" class="btn">See the data →</a>
        <a href="/methodology" class="btn btn-ghost">How it works</a>
      </div>
    </div>
  </section>

  <!-- The problem -->
  <section class="problem">
    <div class="container">
      <div class="section-label">The problem</div>
      <h2>Synthetic data often can't be defended.</h2>
      <div class="problem-grid">
        <div class="problem-item">
          <div class="problem-number">01</div>
          <h3>Unsourced values</h3>
          <p>
            When a reviewer asks where a figure came from, the honest answer is
            often "the model made it up."
          </p>
        </div>
        <div class="problem-item">
          <div class="problem-number">02</div>
          <h3>Non-reproducible</h3>
          <p>
            Most tools can't regenerate the same dataset twice. Research built
            on them isn't independently verifiable.
          </p>
        </div>
        <div class="problem-item">
          <div class="problem-number">03</div>
          <h3>No external audit</h3>
          <p>
            Quality claims without adversarial review are marketing. Without
            continuous scrutiny, errors accumulate silently.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- The answer -->
  <section class="answer">
    <div class="container">
      <div class="section-label">How Rhysora is different</div>
      <h2>Built for scrutiny.</h2>
      <div class="answer-grid">
        <div class="answer-card reveal">
          <div class="answer-icon">◈</div>
          <h3>Values traceable to sources</h3>
          <p>
            Clinical thresholds, drug doses, prescribing patterns, mortality
            rates. Values trace to published sources; values we cannot
            source are flagged as estimates.
          </p>
        </div>
        <div class="answer-card reveal">
          <div class="answer-icon">◊</div>
          <h3>Fully reproducible</h3>
          <p>
            Run Rhysora twice with the same settings and get the exact same
            dataset. Every run, every computer. Your work is verifiable by
            anyone.
          </p>
        </div>
        <div class="answer-card reveal">
          <div class="answer-icon">◇</div>
          <h3>Routinely audited</h3>
          <p>
            Outputs are reviewed against published pharmacoepidemiology
            standards. Findings are logged, triaged, and resolved in
            versioned releases.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Product callout -->
  <section class="product-callout">
    <div class="container">
      <div class="callout-inner">
        <div>
          <div class="section-label">Available now</div>
          <h2>Practice Extract</h2>
          <p class="callout-lead">
            Realistic synthetic patient cohorts in the standard UK primary-care
            research format. Any size, any location, any reference date.
            Reproducible by seed.
          </p>
          <a href="/products" class="btn">Learn more →</a>
        </div>
        <div class="callout-visual">
          <div class="mock-extract">
            <div class="mock-header">
              <span class="mock-dot"></span>
              <span class="mock-dot"></span>
              <span class="mock-dot"></span>
              <span class="mock-title">practice_extract.tsv</span>
            </div>
            <div class="mock-body">
              <div class="mock-line mock-header-row"><span class="mono subtle">patid</span><span class="mono muted">pracid</span><span class="mono muted">gender</span><span class="mono muted">yob</span></div>
              <div class="mock-scroll" aria-hidden="true">
                <div class="mock-track" id="mock-track"></div>
                <div class="mock-fade-top"></div>
                <div class="mock-fade-bottom"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="final-cta">
    <div class="container">
      <h2>Building something that needs trustworthy synthetic data?</h2>
      <p class="muted">Get in touch. We respond personally.</p>
      <a href="/contact" class="btn">Contact us →</a>
    </div>
  </section>

</Base>

<style>
  /* Hero */
  .hero {
    position: relative;
    padding: var(--space-24) 0 var(--space-16);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 30%, var(--accent-glow) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 80%, rgba(139, 92, 246, 0.08) 0%, transparent 50%);
    pointer-events: none;
  }

  .hero-hex {
    position: absolute;
    top: 0;
    right: 0;
    width: 60%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .hero-hex svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Hide hex grid on mobile — hero needs to breathe on small screens */
  @media (max-width: 640px) {
    .hero-hex {
      display: none;
    }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
  }

  .hero-tag {
    display: inline-block;
    padding: var(--space-2) var(--space-3);
    background: var(--surface);
    border: 1px solid var(--border-strong);
    border-radius: 100px;
    font-size: 0.85rem;
    color: var(--fg-muted);
    margin-bottom: var(--space-6);
  }

  .hero h1 {
    margin-bottom: var(--space-6);
    max-width: 640px;
  }

  .hero-lead {
    font-size: 1.2rem;
    line-height: 1.55;
    color: var(--fg-muted);
    margin-bottom: var(--space-8);
    max-width: 640px;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  /* Section labels */
  .section-label {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent);
    margin-bottom: var(--space-3);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* Problem section */
  .problem-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-8);
    margin-top: var(--space-8);
  }

  .problem-item {
    position: relative;
    padding-top: var(--space-6);
  }

  .problem-number {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--fg-subtle);
    margin-bottom: var(--space-3);
  }

  /* Answer section */
  .answer {
    background: var(--bg-elevated);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .answer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-4);
    margin-top: var(--space-8);
  }

  .answer-card {
    padding: var(--space-8);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .answer-card:hover {
    border-color: var(--accent-dim);
    transform: translateY(-2px);
  }

  .answer-icon {
    font-size: 1.5rem;
    color: var(--accent);
    margin-bottom: var(--space-4);
  }

  /* Product callout */
  .product-callout {
    background: var(--bg);
  }

  .callout-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  @media (min-width: 900px) {
    .callout-inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-16);
    }
  }

  .callout-lead {
    font-size: 1.1rem;
    margin-bottom: var(--space-6);
  }

  /* Mock extract visual */
  .mock-extract {
    background: var(--bg-elevated);
    border: 1px solid var(--border-strong);
    border-radius: 10px;
    overflow: hidden;
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }

  .mock-header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    background: var(--surface);
    border-bottom: 1px solid var(--border);
  }

  .mock-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--border-strong);
  }

  .mock-title {
    margin-left: var(--space-3);
    color: var(--fg-muted);
    font-size: 0.85rem;
  }

  .mock-body {
    padding: var(--space-4);
  }

  .mock-line {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-3);
    padding: var(--space-2) 0;
  }

  .mock-header-row {
    border-bottom: 1px solid var(--border-strong);
    padding-bottom: var(--space-3);
    margin-bottom: var(--space-2);
  }

  .mock-scroll {
    position: relative;
    height: 168px;
    overflow: hidden;
    mask-image: linear-gradient(to bottom, transparent 0, #000 18px, #000 calc(100% - 24px), transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, transparent 0, #000 18px, #000 calc(100% - 24px), transparent 100%);
  }

  .mock-track {
    display: flex;
    flex-direction: column;
  }

  .mock-track .mock-line {
    border-bottom: 1px solid var(--border);
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.45s ease, transform 0.45s ease;
  }
  .mock-track .mock-line.enter {
    opacity: 0;
    transform: translateY(8px);
  }

  .mock-track .mock-line.flash .mono {
    color: var(--accent);
    transition: color 1.4s ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .mock-track .mock-line { animation: none; opacity: 1; }
  }

  .mock-dim {
    opacity: 0.5;
  }

  /* Final CTA */
  .final-cta {
    text-align: center;
    padding: var(--space-24) 0;
    background: var(--bg-elevated);
  }

  .final-cta h2 {
    margin-bottom: var(--space-4);
  }

  .final-cta p {
    margin: 0 auto var(--space-8);
  }

  /* Hex grid: breathing accents + traveling pulses */
  .hex-accent polygon {
    transform-box: fill-box;
    transform-origin: center;
    animation: hexBreath 7s ease-in-out infinite;
  }
  .hex-accent polygon:nth-child(1) { animation-delay: 0s; }
  .hex-accent polygon:nth-child(2) { animation-delay: 1.4s; }
  .hex-accent polygon:nth-child(3) { animation-delay: 2.8s; }
  .hex-accent polygon:nth-child(4) { animation-delay: 4.2s; }
  .hex-accent polygon:nth-child(5) { animation-delay: 5.6s; }
  @keyframes hexBreath {
    0%, 100% { opacity: 0.35; }
    50%      { opacity: 0.65; }
  }

  .hex-trace {
    fill: none;
    stroke: #5eead4;
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
    filter: drop-shadow(0 0 5px rgba(94, 234, 212, 0.7));
  }

  @media (prefers-reduced-motion: reduce) {
    .hex-accent polygon { animation: none; }
    .hex-trace { display: none; }
  }
</style>


<script is:inline>
  (function () {
    const svgNS = 'http://www.w3.org/2000/svg';
    const base = document.getElementById('hero-hex-base');
    const traces = document.getElementById('hero-hex-traces');
    if (!base || !traces) return;

    const reduceMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const hexPoints = (cx, cy) => [
      [cx,      cy - 22],
      [cx + 19, cy - 11],
      [cx + 19, cy + 11],
      [cx,      cy + 22],
      [cx - 19, cy + 11],
      [cx - 19, cy - 11],
    ];
    const ptsAttr = (pts) => pts.map((p) => p[0] + ',' + p[1]).join(' ');

    const centers = [];
    const ROWS = 9, COLS = 19;
    for (let r = 0; r < ROWS; r++) {
      for (let c = 0; c < COLS; c++) {
        const cx = 100 + c * 38;
        const cy = 50 + r * 68 + (c % 2 === 1 ? 22 : 0);
        centers.push({ cx, cy, r, c });
        const poly = document.createElementNS(svgNS, 'polygon');
        poly.setAttribute('points', ptsAttr(hexPoints(cx, cy)));
        base.appendChild(poly);
      }
    }

    if (reduceMotion) return;

    const neighbors = (cell) =>
      centers
        .filter((o) => o !== cell)
        .map((o) => ({ o, d: Math.hypot(o.cx - cell.cx, o.cy - cell.cy) }))
        .filter((x) => x.d < 45)
        .sort((a, b) => a.d - b.d)
        .map((x) => x.o);

    const buildWalk = (start, steps) => {
      const visited = new Set([start.r + ',' + start.c]);
      const path = [start];
      let cur = start;
      for (let i = 0; i < steps; i++) {
        const nbrs = neighbors(cur).filter((n) => !visited.has(n.r + ',' + n.c));
        if (!nbrs.length) break;
        const pick = nbrs[Math.floor(Math.random() * nbrs.length)];
        path.push(pick);
        visited.add(pick.r + ',' + pick.c);
        cur = pick;
      }
      return path;
    };

    // Build ordered set of vertices + edges.
    // Deduplicate vertices: two hexes share a vertex if their points are nearly equal.
    const vertexKey = (x, y) => Math.round(x) + '_' + Math.round(y);
    const vertexMap = new Map(); // key -> {x, y, neighbors: Set<key>}
    const ensureV = (x, y) => {
      const k = vertexKey(x, y);
      if (!vertexMap.has(k)) vertexMap.set(k, { x, y, key: k, nbrs: new Set() });
      return vertexMap.get(k);
    };
    // Build graph by walking every hex's perimeter
    centers.forEach((cell) => {
      const hx = hexPoints(cell.cx, cell.cy);
      const verts = hx.map(([x, y]) => ensureV(x, y));
      for (let i = 0; i < 6; i++) {
        const a = verts[i], b = verts[(i + 1) % 6];
        a.nbrs.add(b.key);
        b.nbrs.add(a.key);
      }
    });
    const allVerts = Array.from(vertexMap.values());

    // Random walk along hex-grid edges, preferring not to immediately backtrack.
    const buildEdgeWalk = (startV, steps) => {
      const pts = [[startV.x, startV.y]];
      let cur = startV, prevKey = null;
      for (let i = 0; i < steps; i++) {
        const options = Array.from(cur.nbrs).filter((k) => k !== prevKey);
        const pool = options.length ? options : Array.from(cur.nbrs);
        if (!pool.length) break;
        const nextKey = pool[Math.floor(Math.random() * pool.length)];
        const next = vertexMap.get(nextKey);
        pts.push([next.x, next.y]);
        prevKey = cur.key;
        cur = next;
      }
      return pts;
    };

    const spawnTrace = ({ startV, steps, duration, delay }) => {
      const pts = buildEdgeWalk(startV, steps);
      if (pts.length < 2) return;
      const d = 'M ' + pts.map((p) => p[0] + ' ' + p[1]).join(' L ');
      const path = document.createElementNS(svgNS, 'path');
      path.setAttribute('d', d);
      path.setAttribute('class', 'hex-trace');
      traces.appendChild(path);

      const len = path.getTotalLength();
      const dashLen = 38;
      path.style.strokeDasharray = dashLen + ' ' + (len + dashLen);
      path.style.strokeDashoffset = len + dashLen;

      const anim = path.animate(
        [
          { strokeDashoffset: len + dashLen, opacity: 0 },
          { strokeDashoffset: len + dashLen - 8, opacity: 1, offset: 0.05 },
          { strokeDashoffset: dashLen, opacity: 1, offset: 0.9 },
          { strokeDashoffset: -4, opacity: 0 },
        ],
        { duration: duration, delay: delay, easing: 'linear', fill: 'forwards' }
      );
      anim.onfinish = () => path.remove();
    };

    const pickStartV = () => allVerts[Math.floor(Math.random() * allVerts.length)];

    // Seed pulses, staggered.
    for (let i = 0; i < 5; i++) {
      spawnTrace({
        startV: pickStartV(),
        steps: 14 + Math.floor(Math.random() * 10),
        duration: 8000 + Math.random() * 4000,
        delay: i * 1400,
      });
    }

    setInterval(() => {
      if (document.hidden) return;
      spawnTrace({
        startV: pickStartV(),
        steps: 12 + Math.floor(Math.random() * 12),
        duration: 8000 + Math.random() * 4000,
        delay: 0,
      });
    }, 2600);
  })();
</script>

<script is:inline>
  (function () {
    const track = document.getElementById('mock-track');
    if (!track) return;
    const reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const genders = ['F', 'M', 'F', 'M'];
    const pracids = ['8241', '8241', '8241', '8376', '8241', '6102'];
    let nextId = 1029341;

    const makeRow = (flash) => {
      const patid = (nextId++).toString();
      const pracid = pracids[Math.floor(Math.random() * pracids.length)];
      const gender = genders[Math.floor(Math.random() * genders.length)];
      const yob = 1935 + Math.floor(Math.random() * 70);
      const row = document.createElement('div');
      row.className = flash ? 'mock-line flash' : 'mock-line';
      row.innerHTML =
        '<span class="mono">' + patid + '</span>' +
        '<span class="mono">' + pracid + '</span>' +
        '<span class="mono">' + gender + '</span>' +
        '<span class="mono">' + yob + '</span>';
      return row;
    };

    // Seed with enough rows to fill the mask, plus a few extras below the fold.
    for (let i = 0; i < 10; i++) track.appendChild(makeRow(false));

    if (reduce) return;

    // Endless ticker: keep appending fresh rows and removing the oldest so the list
    // always has content visible inside the mask.
    setInterval(() => {
      if (document.hidden) return;
      const r = makeRow(true);
      track.appendChild(r);
      setTimeout(() => r.classList.remove('flash'), 1400);
      // Keep the DOM bounded but NEVER let the track become empty.
      while (track.children.length > 14) track.removeChild(track.firstChild);
    }, 900);
    })();
</script>

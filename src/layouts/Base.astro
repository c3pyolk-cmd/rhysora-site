---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Trustworthy synthetic UK primary-care data. Every value sourced, every run reproducible."
} = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    rel="stylesheet"
  />

  <title>{title}</title>

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`https://rhysora.com${Astro.url.pathname}`} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta property="og:image" content="https://rhysora.com/og-image.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="Rhysora" />
  <meta name="twitter:image" content="https://rhysora.com/og-image.png" />
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="brand">
        <img src="/logo.png" alt="Rhysora" class="brand-logo" />
        <span>Rhysora</span>
      </a>
      <nav>
        <a href="/">Home</a>
        <a href="/products">Products</a>
        <a href="/methodology">Methodology</a>
        <a href="/contact">Contact</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <img src="/logo.png" alt="Rhysora" class="brand-logo" />
        <span>Rhysora</span>
      </div>

      <p class="footer-disclaimer">
        Rhysora is synthetic data. Not real patient data. Not a substitute
        for real-world evidence where regulators require real data.
      </p>

      <nav class="footer-nav">
        <a href="/">Home</a>
        <a href="/products">Products</a>
        <a href="/methodology">Methodology</a>
        <a href="/contact">Contact</a>
        <a href="/privacy">Privacy</a>
        <a href="/terms">Terms</a>
      </nav>

      <p class="footer-company">
        Wilrhys Limited · Company No. 15731165 · Registered in England and Wales
        · Stevenage, Hertfordshire
      </p>

      <p class="footer-copyright">© 2026 Wilrhys Limited. All rights reserved.</p>
    </div>
  </footer>

  <script>
    // Scroll reveal
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      },
      { threshold: 0.1 }
    );

    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
  </script>
</body>
</html>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10, 14, 26, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 32px;
    padding: 16px 32px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--fg);
    font-weight: 600;
    font-size: 1.05rem;
    flex-shrink: 0;
    text-decoration: none;
  }

  .brand:hover {
    opacity: 1;
  }

  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: var(--accent);
    color: var(--bg);
    border-radius: 6px;
    font-weight: 700;
    font-size: 0.9rem;
  }

  .brand-logo {
    width: 28px;
    height: 28px;
    display: block;
    object-fit: contain;
  }

  nav {
    display: flex;
    gap: 28px;
    flex-wrap: nowrap;
    align-items: center;
  }

  nav a {
    color: var(--fg-muted);
    font-size: 0.95rem;
    font-weight: 500;
    white-space: nowrap;
    text-decoration: none;
  }

  nav a:hover {
    color: var(--fg);
    opacity: 1;
  }

  @media (max-width: 640px) {
    .header-inner {
      gap: 12px;
      padding: 12px 16px;
    }

    .brand span:last-child {
      display: none;
    }

    nav {
      gap: 16px;
    }

    nav a {
      font-size: 0.85rem;
    }
  }

  @media (max-width: 380px) {
    nav {
      gap: 10px;
    }

    nav a {
      font-size: 0.8rem;
    }
  }

  .footer {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding: 64px 0 40px;
    margin-top: 120px;
    background: transparent;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 28px;
    align-items: flex-start;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--fg);
    font-weight: 600;
    font-size: 1.05rem;
  }

  .footer-disclaimer {
    color: var(--fg-muted);
    font-size: 0.9rem;
    line-height: 1.55;
    max-width: 720px;
    margin: 0;
  }

  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    margin: 0;
  }

  .footer-nav a {
    color: var(--fg-muted);
    font-size: 0.9rem;
    text-decoration: none;
  }

  .footer-nav a:hover {
    color: var(--fg);
  }

  .footer-company {
    color: var(--fg-muted);
    font-size: 0.8rem;
    margin: 0;
    line-height: 1.6;
    padding-top: 8px;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
    width: 100%;
  }

  .footer-copyright {
    color: var(--fg-muted);
    font-size: 0.8rem;
    margin: 0;
    line-height: 1.5;
    opacity: 0.7;
  }

  @media (max-width: 640px) {
    .footer-inner {
      gap: 16px;
    }

    .footer-nav {
      gap: 14px;
    }
  }
</style>

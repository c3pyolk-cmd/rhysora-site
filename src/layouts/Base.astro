---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Trustworthy synthetic UK primary-care data. Every value sourced, every run reproducible."
} = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    rel="stylesheet"
  />

  <title>{title}</title>

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`https://rhysora.com${Astro.url.pathname}`} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta property="og:image" content="https://rhysora.com/og-image.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="Rhysora" />
  <meta name="twitter:image" content="https://rhysora.com/og-image.png" />
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="brand">
        <img src="/logo.png" alt="Rhysora" class="brand-logo" />
        <span>Rhysora</span>
      </a>
      <nav>
        <a href="/">Home</a>
        <a href="/products">Products</a>
        <a href="/methodology">Methodology</a>
        <a href="/contact">Contact</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <div>
        <img src="/logo.png" alt="Rhysora" class="brand-logo" />
        <span>Rhysora</span>
      </div>
      <div class="footer-links">
        <a href="/products">Products</a>
        <a href="/methodology">Methodology</a>
        <a href="/contact">Contact</a>
      </div>
      <div class="footer-note">
        &copy; 2026 Rhysora. Synthetic data for UK primary care research.
      </div>
    </div>
  </footer>

  <script>
    // Scroll reveal
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      },
      { threshold: 0.1 }
    );

    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
  </script>
</body>
</html>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10, 14, 26, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 32px;
    padding: 16px 32px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--fg);
    font-weight: 600;
    font-size: 1.05rem;
    flex-shrink: 0;
    text-decoration: none;
  }

  .brand:hover {
    opacity: 1;
  }

  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: var(--accent);
    color: var(--bg);
    border-radius: 6px;
    font-weight: 700;
    font-size: 0.9rem;
  }

  .brand-logo {
    width: 28px;
    height: 28px;
    display: block;
    object-fit: contain;
  }

  nav {
    display: flex;
    gap: 28px;
    flex-wrap: nowrap;
    align-items: center;
  }

  nav a {
    color: var(--fg-muted);
    font-size: 0.95rem;
    font-weight: 500;
    white-space: nowrap;
    text-decoration: none;
  }

  nav a:hover {
    color: var(--fg);
    opacity: 1;
  }

  @media (max-width: 640px) {
    .header-inner {
      gap: 12px;
      padding: 12px 16px;
    }

    .brand span:last-child {
      display: none;
    }

    nav {
      gap: 16px;
    }

    nav a {
      font-size: 0.85rem;
    }
  }

  @media (max-width: 380px) {
    nav {
      gap: 10px;
    }

    nav a {
      font-size: 0.8rem;
    }
  }

  .site-footer {
    border-top: 1px solid var(--border);
    padding: var(--space-12) 0;
    margin-top: var(--space-24);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    color: var(--fg-subtle);
    font-size: 0.9rem;
  }

  .footer-inner > div:first-child {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--fg);
    font-weight: 600;
  }

  .footer-links {
    display: flex;
    gap: var(--space-6);
  }

  .footer-links a {
    color: var(--fg-muted);
    font-size: 0.9rem;
  }

  .footer-note {
    color: var(--fg-subtle);
    font-size: 0.85rem;
  }

  @media (min-width: 640px) {
    .footer-inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }
</style>
